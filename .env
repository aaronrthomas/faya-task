# ── Django Core ──
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True

# ── API Configuration ──
# Base URL for all API endpoints (no trailing slash)
# Change this to your deployed domain when hosting remotely
# e.g. https://your-app.onrender.com/api
API_BASE_URL=/api

# ── API Endpoints (built from API_BASE_URL) ──
# GET  ${API_BASE_URL}/products/                     → list all products
# GET  ${API_BASE_URL}/products/<id>/                → single product detail
# GET  ${API_BASE_URL}/products/<id>/views/           → all views for a product
# POST ${API_BASE_URL}/products/views/<id>/reanalyze/ → re-trigger analysis
# POST ${API_BASE_URL}/render/                        → submit render job
# POST ${API_BASE_URL}/render/all/                    → render all views
# GET  ${API_BASE_URL}/render/<job_id>/status/        → poll render status
# GET  ${API_BASE_URL}/render/<job_id>/result/        → get render result

# ── Database ──
# Uncomment and fill these in for PostgreSQL. Leave commented for SQLite default.
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=printcraft_db
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# ── Celery / Redis ──
# Uncomment when using Redis in production
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_ASYNC=false
USE_REDIS=false
# REDIS_URL=redis://localhost:6379/1

# ── Allowed Hosts ──
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=*,.vercel.app,faya-task.vercel.app,localhost,127.0.0.1
